# EconoMe configuration — all runtime config is via environment variables
# (12-factor; technical/07 §3). Copy to .env for local use or set these in the
# deployment environment. NEVER commit real secrets; only this example is
# tracked. The session secret is NOT here — it is auto-generated on first run
# and persisted to ECONOME_DATA_DIR/secret.key (technical/05 §4).

# Directory for the SQLite file + secret + backups. In production this is the
# MOUNTED VOLUME — the single rule that keeps data safe across Watchtower image
# updates. The app refuses to start if it is not writable.
ECONOME_DATA_DIR=/data

# Internal HTTP listen address (TLS is terminated upstream by the reverse proxy).
ECONOME_LISTEN=:8080

# Set Secure cookies + HSTS. 1 in production (behind an HTTPS proxy); 0 for local
# http://localhost development (start.bat sets this to 0).
ECONOME_BEHIND_TLS=1

# Reverse-proxy IP/CIDR whose X-Forwarded-For header is trusted by the per-IP
# login throttle (technical/05 §6). Leave empty when not behind a known proxy.
ECONOME_TRUSTED_PROXY=

# Signed-out locale fallback: "fr" or "en".
ECONOME_DEFAULT_LOCALE=fr

# Structured-log level: debug | info | warn | error.
ECONOME_LOG_LEVEL=info

# Optional override for the on-volume session secret path (default:
# ECONOME_DATA_DIR/secret.key). Set only if the operator manages the secret.
# ECONOME_SECRET_FILE=

# --- Operator-tunable security parameters (documented defaults applied when
# unset; wired in the auth increments, technical/05 §1, functional/01 §1.3). ---
# ECONOME_ARGON2_MEMORY_KIB=
# ECONOME_ARGON2_ITERATIONS=
# ECONOME_ARGON2_PARALLELISM=
# ECONOME_SESSION_LIFETIME=
# ECONOME_SESSION_IDLE_TIMEOUT=
# ECONOME_LOCKOUT_THRESHOLD=
